<!DOCTYPE html><html><head><meta charset="UTF-8">
<style>{{ css }}
@page { size: A4; margin: 1.5cm; }
.template { display: block !important; page-break-after: always; max-width: none; padding: 0; }
.nav, .dl-bar { display: none; }
.svc-table { font-size: 11px; }
.svc-table th, .svc-table td { padding: 5px 8px; }
tr { page-break-inside: avoid; }
</style></head><body>

{% set badge = 'badge-pass' if s.errors == 0 else 'badge-warn' %}
{% set verdict_cls = 'verdict-pass' if s.errors == 0 else 'verdict-warn' %}
{% set status_text = '✓ Ready for GA' if s.errors == 0 else '⚠ Attention Required' %}
{% set err_services = s.services | selectattr('errors') | map(attribute='service') | list %}
{% set SCORECARD_LIMIT = 10 %}

{% macro svc_badge(svc) %}
  {%- if svc.errors -%}<span class="badge badge-err">Error</span>
  {%- elif svc.warnings -%}<span class="badge badge-warn">Warning</span>
  {%- elif svc.incomplete and not svc.passed -%}<span class="badge badge-inc">Incomplete</span>
  {%- else -%}<span class="badge badge-pass">Pass</span>{%- endif -%}
{% endmacro %}

{# Stacked progress bar: proportional pass / error / warning / incomplete segments #}
{% macro prog(svc) %}
  {%- set t = svc.checked if svc.checked else 1 -%}
  <div class="prog-bar" style="display:flex;width:120px;">
    {%- if svc.passed %}<div style="background:#1e7e34;width:{{ (100 * svc.passed / t)|round(3) }}%;"></div>{% endif -%}
    {%- if svc.errors %}<div style="background:#c62828;width:{{ (100 * svc.errors / t)|round(3) }}%;"></div>{% endif -%}
    {%- if svc.warnings %}<div style="background:#e65100;width:{{ (100 * svc.warnings / t)|round(3) }}%;"></div>{% endif -%}
    {%- if svc.incomplete %}<div style="background:#bbb;width:{{ (100 * svc.incomplete / t)|round(3) }}%;"></div>{% endif -%}
  </div>
{% endmacro %}

{% macro prog_legend() %}
  <div class="legend-row">
    <div class="legend-item"><span class="dot dot-pass"></span>Pass</div>
    <div class="legend-item"><span class="dot dot-err"></span>Error</div>
    <div class="legend-item"><span class="dot dot-warn"></span>Warning</div>
    <div class="legend-item"><span class="dot dot-inc"></span>Incomplete</div>
  </div>
{% endmacro %}

<!-- PAGE 1 — EXECUTIVE -->
<div class="template">
  <div class="report-card">
    <div class="report-header">
      <div>
        <div class="oracle-logo">ORACLE CLOUD INFRASTRUCTURE</div>
        <div class="report-title" style="margin-top:6px;">Region Readiness Report</div>
        <div class="report-sub">{{ cfg.customer_name }} · {{ cfg.region_label }}</div>
        <div class="report-sub">Validation run: {{ cfg.validation_run_date }} · Prepared by Oracle Cloud</div>
      </div>
      <span class="badge {{ badge }}" style="font-size:12px;padding:5px 14px;">{{ status_text }}</span>
    </div>

    <div class="verdict {{ verdict_cls }}">
      Service limit validation for your region is complete.
      {% if s.errors or s.warnings %}
      <strong>{{ s.errors }} errors</strong> and <strong>{{ s.warnings }} warnings</strong> were identified that require resolution before your region can be confirmed as production-ready.
      {% else %}
      All {{ s.total_checked }} checked limits match the approved manifest.
      {% endif %}
    </div>

    <div class="metric-row">
      <div class="metric"><div class="ml">Limits validated</div><div class="mv">{{ "{:,}".format(s.total_checked) }}</div></div>
      <div class="metric"><div class="ml">Passed</div><div class="mv c-pass">{{ "{:,}".format(s.passed) }}</div></div>
      <div class="metric"><div class="ml">Errors</div><div class="mv c-err">{{ "{:,}".format(s.errors) }}</div></div>
      <div class="metric"><div class="ml">Warnings</div><div class="mv c-warn">{{ "{:,}".format(s.warnings) }}</div></div>
    </div>

    <div class="chart-grid">
      <div><div class="section-label">Results overview</div><img src="{{ doughnut_uri }}" style="max-width:100%;"></div>
      <div><div class="section-label">Top services by errors</div><img src="{{ bar_uri }}" style="max-width:100%;"></div>
    </div>

    <hr class="divider">
    <div class="section-label">Support</div>
    <div style="font-size:13px;color:#555;">Found an issue not covered in this report? Raise a JIRA ticket with your Oracle team: {{ cfg.jira_url }}</div>
    <div class="footer-note" style="margin-top:1.5rem;">Generated by the Oracle DRCC Validation Agent · Confidential · For customer use only</div>
  </div>
</div>

<!-- PAGE 2 — SCORECARD (top 10) -->
<div class="template">
  <div class="report-card">
    <div class="report-header">
      <div>
        <div class="oracle-logo">ORACLE CLOUD INFRASTRUCTURE</div>
        <div class="report-title" style="margin-top:6px;">Service Scorecard</div>
        <div class="report-sub">{{ cfg.customer_name }} · {{ cfg.region_label }} · {{ cfg.validation_run_date }}</div>
      </div>
      <span class="badge {{ badge }}" style="font-size:12px;padding:5px 14px;">{{ status_text }}</span>
    </div>

    <div class="meta-grid">
      <div class="meta-cell"><div class="meta-key">Customer</div><div class="meta-val">{{ cfg.customer_name }}</div></div>
      <div class="meta-cell"><div class="meta-key">Region</div><div class="meta-val">{{ cfg.region_label }}</div></div>
      <div class="meta-cell"><div class="meta-key">GA Target</div><div class="meta-val">{{ cfg.ga_target_date }}</div></div>
      <div class="meta-cell"><div class="meta-key">Services Checked</div><div class="meta-val">{{ s.services|length }} / {{ s.services|length }}</div></div>
    </div>

    <div class="section-label">Per-service results — top {{ SCORECARD_LIMIT }} by errors</div>
    {{ prog_legend() }}
    <table class="svc-table">
      <thead><tr><th>Service</th><th>Status</th><th>Checked</th><th>Pass</th><th>Errors</th><th>Warnings</th><th>Progress</th></tr></thead>
      <tbody>
      {% for svc in s.services[:SCORECARD_LIMIT] %}
        <tr><td>{{ svc.service }}</td><td>{{ svc_badge(svc) }}</td><td>{{ svc.checked }}</td><td>{{ svc.passed }}</td><td>{{ svc.errors }}</td><td>{{ svc.warnings }}</td><td>{{ prog(svc) }}</td></tr>
      {% endfor %}
      </tbody>
    </table>
    <div style="font-size:12px;color:#aaa;margin-top:8px;">Showing top {{ [SCORECARD_LIMIT, s.services|length]|min }} of {{ s.services|length }} services (ranked by error count). Per-limit detail is in the Validation Limits report.</div>
    <div class="footer-note" style="margin-top:1.5rem;">Oracle DRCC Validation Agent · Confidential · For customer use only</div>
  </div>
</div>

<!-- PAGE 3 — CERTIFICATE -->
<div class="template" style="page-break-after:auto;">
  <div class="report-card">
    <div style="text-align:center;padding:1rem 0;">
      <div class="oracle-logo" style="margin-bottom:8px;">ORACLE CLOUD INFRASTRUCTURE</div>
      <div class="report-title">Region Readiness Certificate</div>
      <div class="report-sub" style="margin-top:4px;">{{ cfg.customer_name }} · {{ cfg.region_label }} · {{ cfg.validation_run_date }}</div>
    </div>
    <hr class="divider">

    {% if s.errors %}
    <div style="display:flex;align-items:center;gap:1.5rem;background:#fff8f3;border:1px solid #ffe0c0;border-radius:10px;padding:1.25rem;margin-bottom:1.5rem;">
      <div style="text-align:center;min-width:72px;">
        <div style="font-size:40px;font-weight:700;color:#e65100;line-height:1;">{{ s.errors }}</div>
        <div style="font-size:11px;color:#999;margin-top:2px;">items need attention</div>
      </div>
      <div style="flex:1;">
        <div style="font-size:16px;font-weight:600;color:#1a1a1a;margin-bottom:4px;">Not yet certified for GA</div>
        <div style="font-size:13px;color:#555;line-height:1.7;">Service limit validation identified discrepancies{% if err_services %} in <strong>{{ err_services[0] }}</strong>{% if err_services|length > 1 %} and <strong>{{ err_services[1] }}</strong>{% endif %}{% if err_services|length > 2 %} and other{% endif %} services{% endif %}. Oracle is working to resolve these before your GA date of <strong>{{ cfg.ga_target_date }}</strong>.</div>
      </div>
    </div>
    {% else %}
    <div style="display:flex;align-items:center;gap:1.5rem;background:#f0faf3;border:1px solid #c6e8d2;border-radius:10px;padding:1.25rem;margin-bottom:1.5rem;">
      <div style="text-align:center;min-width:72px;">
        <div style="font-size:40px;font-weight:700;color:#1e7e34;line-height:1;">✓</div>
        <div style="font-size:11px;color:#999;margin-top:2px;">all limits confirmed</div>
      </div>
      <div style="flex:1;">
        <div style="font-size:16px;font-weight:600;color:#1a1a1a;margin-bottom:4px;">Certified for GA</div>
        <div style="font-size:13px;color:#555;line-height:1.7;">All {{ s.total_checked }} validated service limits match the approved manifest for your GA date of <strong>{{ cfg.ga_target_date }}</strong>.</div>
      </div>
    </div>
    {% endif %}

    <div class="pill-row">
      <div class="pill"><span class="dot dot-pass"></span><span>{{ "{:,}".format(s.passed) }} limits confirmed</span></div>
      <div class="pill"><span class="dot dot-err"></span><span>{{ "{:,}".format(s.errors) }} errors</span></div>
      <div class="pill"><span class="dot dot-warn"></span><span>{{ "{:,}".format(s.warnings) }} warnings</span></div>
      <div class="pill"><span class="dot dot-inc"></span><span>{{ "{:,}".format(s.incomplete) }} incomplete</span></div>
    </div>

    <div class="footer-note" style="margin-top:1.5rem;">Oracle DRCC Validation Agent · Confidential · For customer use only</div>
  </div>
</div>
</body></html>
